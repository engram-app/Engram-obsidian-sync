{
  "name": "engram-obsidian",
  "version": "1.3.27",
  "description": "Sync your vault and search it by meaning with AI. Use the hosted service or self-host for free. Works with Claude, Cursor, and any tool that speaks MCP.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check src tests",
    "lint:obsidian": "eslint -c eslint.config.mjs --max-warnings 0 'src/**/*.ts'",
    "lint:css": "stylelint --max-warnings 0 styles.css",
    "format": "biome format --write src tests",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "prepare": "lefthook install"
  },
  "keywords": [
    "obsidian",
    "engram",
    "sync",
    "knowledge-base"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@types/bun": "^1.2.0",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^22.19.17",
    "@typescript-eslint/parser": "^8.59.3",
    "esbuild": "^0.25.0",
    "eslint": "^10.3.0",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.6.0",
    "lefthook": "^2.1.6",
    "obsidian": "1.8.7",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  },
  "dependencies": {
    "diff-match-patch": "^1.0.5"
  },
  "overrides": {
    "brace-expansion": "^1.1.13",
    "picomatch": "^2.3.2"
  }
}
